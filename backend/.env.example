# ===========================================
# LearnFlow Backend Configuration
# Copy this file to .env and fill in your values
# ===========================================

# --- LLM API Configuration ---
# Any OpenAI-compatible API endpoint
# Leave empty to use built-in topic_library fallback (no LLM)
LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=

# --- Server Configuration ---
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8001

# --- Notification CLI Paths (optional) ---
# Override default CLI binary paths for Feishu/DingTalk notifications
# LARK_CLI_PATH=/path/to/lark-cli
# DWS_CLI_PATH=/path/to/dws

# --- Database ---
# DB_PATH is auto-detected relative to project root
# Override only if you need a custom location
# DB_PATH=/custom/path/to/learnflow.db
